<Window x:Class="MyFirstWPFApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
    Icon="favicon.ico"
    Title="Pnat Clicker"
    FontFamily="Segoe UI"
    FontSize="12"
    Height="760" Width="760"
    MinHeight="640" MinWidth="620"
    ResizeMode="CanResizeWithGrip"
    SizeToContent="Manual"
    Loaded="Window_Loaded"
    Closed="Window_Closed">

    <Window.Resources>

        <!-- WindowButton style: icon-only, no border, subtle hover -->
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2D313A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CloseButton style: red bij hover -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#AA5F3B5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary action button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#D946EF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E879F9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E855FF"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#F0A4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C41CE3"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#D867F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary action button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1F1F2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3A3A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#262635"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#5A5A6A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#151520"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161618"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="CaretBrush" Value="#D946EF"/>
            <Setter Property="BorderBrush" Value="#3A3A45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#AAD946EF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#161618"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#3A3A45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#161618"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1F1F2E"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FBD34D"/>
                    <Setter Property="Foreground" Value="#0A0A0A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                                <Border x:Name="Box" Width="18" Height="18" CornerRadius="4"
                                    BorderBrush="#3A3A45" BorderThickness="1" Background="#161618"
                                    VerticalAlignment="Center">
                                <Path x:Name="Tick" Data="M 3 8 L 6 11 L 13 4" Stroke="#10B981" StrokeThickness="2.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#10B981"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#34D399"/>
                                <Setter TargetName="Tick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D0D0D0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Chip" CornerRadius="12" BorderThickness="1" BorderBrush="#3A3A4A" Background="#1F1F2E" Padding="10,4">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="#262635"/>
                                <Setter TargetName="Chip" Property="BorderBrush" Value="#5A5A6A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="#FBD34D"/>
                                <Setter TargetName="Chip" Property="BorderBrush" Value="#FCD34D"/>
                                <Setter Property="Foreground" Value="#0A0A0A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ScrollBar Thumb -->
        <Style x:Key="ModernScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#D946EF" CornerRadius="2" x:Name="ThumbBg"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBg" Property="Background" Value="#E855FF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBg" Property="Background" Value="#F0A4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="2"/>
            <Setter Property="Background" Value="#0A0A0A"/>
            <Setter Property="Margin" Value="0,4,2,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}" Width="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer rounded border -->
    <Border CornerRadius="24" BorderThickness="1" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF2A2A35" Offset="0"/>
                <GradientStop Color="#FF1A1A25" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#20FFFFFF" Offset="0"/>
                <GradientStop Color="#15FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.4"/>
        </Border.Effect>
        <DockPanel>

            <!-- ═══ Title Bar ═══ -->
            <Grid DockPanel.Dock="Top" Height="40" Background="#0F0A0A0A"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: dot + title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Ellipse Width="9" Height="9" Fill="#D3C1FF" Margin="0,0,9,0">
                    </Ellipse>
                    <TextBlock Text="Pnat Clicker" Foreground="#D8D8D8" FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Height="1" VerticalAlignment="Bottom" Background="#15FFFFFF"/>

                <!-- Right: icon-only controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,8,0" HorizontalAlignment="Right">

                    <!-- Minimize -->
                    <Button Style="{StaticResource WindowButton}" Click="Minimize_Click" ToolTip="Minimaliseren">
                        <Canvas Width="14" Height="14">
                                <Line X1="3" Y1="9" X2="11" Y2="9"
                                    Stroke="#B6BDC9" StrokeThickness="1"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Button>

                    <!-- Maximize -->
                    <Button Style="{StaticResource WindowButton}" Click="Maximize_Click" ToolTip="Maximaliseren">
                        <Canvas Width="14" Height="14">
                            <Rectangle Canvas.Left="2" Canvas.Top="2" Width="10" Height="10"
                                       RadiusX="2" RadiusY="2"
                                       Stroke="#B6BDC9" StrokeThickness="1"/>
                            <Rectangle Canvas.Left="5" Canvas.Top="5" Width="4" Height="4"
                                       RadiusX="1" RadiusY="1"
                                       Fill="#B6BDC9" Opacity="0.25"/>
                        </Canvas>
                    </Button>

                    <!-- Close -->
                    <Button Style="{StaticResource CloseButton}" Click="Close_Click" ToolTip="Sluiten">
                        <Canvas Width="14" Height="14">
                                <Line X1="3" Y1="3" X2="11" Y2="11"
                                    Stroke="#E7EAF0" StrokeThickness="1"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Line X1="11" Y1="3" X2="3" Y2="11"
                                    Stroke="#E7EAF0" StrokeThickness="1"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- ═══ Content ═══ -->
            <Grid Margin="22,18,22,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Pnat Clicker" Foreground="#F5F5F5" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="Autoclicker + keyboard scripts opnemen en afspelen." Foreground="#B0B0B0" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer Name="ContentScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel Margin="0,0,4,0">
                        <Border BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="20" Padding="18">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF1A1A23" Offset="0"/>
                                    <GradientStop Color="#FF121218" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.RowSpan="4" VerticalAlignment="Top" Height="1" Margin="4,2,4,0" Background="#15FFFFFF"/>

                                <TextBlock Grid.Row="0" Text="Simple mode" Foreground="#F5F5F5" FontWeight="SemiBold" FontSize="15"/>

                                <Grid Grid.Row="1" Margin="0,14,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="Seconde per klik" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Name="SimpleIntervalSecondsTextBox" Width="140" Style="{StaticResource ModernTextBox}" Text="0.10"/>
                                    </StackPanel>

                                    <CheckBox Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center"
                                              Name="UseCurrentCursorCheckBox"
                                              Content="Klik op huidige cursor (geen vaste locatie)"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Grid>

                                <WrapPanel Grid.Row="2" Margin="0,2,0,12">
                                    <CheckBox Name="CtrlModifierCheckBox" Content="Ctrl" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                    <CheckBox Name="AltModifierCheckBox" Content="Alt" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                    <CheckBox Name="ShiftModifierCheckBox" Content="Shift" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                    <CheckBox Name="WinModifierCheckBox" Content="Win" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                        <TextBlock Text="Key" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                    <ComboBox Name="HotkeyComboBox" Width="140" Style="{StaticResource ModernComboBox}" Margin="0,0,8,8"/>
                                    <Button Content="Opslaan keybind" Width="140" Height="38" Margin="0,0,0,8"
                                            Style="{StaticResource SecondaryButton}" Click="ApplyHotkey_Click"/>
                                </WrapPanel>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,2,0,0">
                                    <Button Name="ToggleAutoClickerButton" Content="Start autoclicker" Width="170" Height="42"
                                            Style="{StaticResource PrimaryButton}" Click="ToggleAutoClickerButton_Click"/>
                                    <TextBlock Name="AutoClickerStatusText" Text="Status: uit" Foreground="#B0B0B0"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="16" Background="#FF1A1A23" Margin="0,12,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                            </Border.Effect>
                        <Expander Name="AdvancedExpander" Header="Advanced functies" Background="Transparent" Foreground="#FFFFFF"
                                  BorderBrush="Transparent" BorderThickness="0" IsExpanded="False"
                                  Expanded="AdvancedExpander_Expanded" Collapsed="AdvancedExpander_Collapsed">
                            <StackPanel Name="AdvancedContentPanel" Margin="16,14,16,16" Opacity="0.98">
                                <Border Height="1" Margin="2,0,2,14" Background="#15FFFFFF"/>
                                <TextBlock Text="Muisinstellingen" Style="{StaticResource SectionLabel}"/>

                                <WrapPanel Margin="0,0,0,14">
                                    <StackPanel Width="120" Margin="0,0,10,10">
                                        <TextBlock Text="X" Foreground="#B0B0B0" Margin="0,0,0,4"/>
                                        <TextBox Name="ClickXTextBox" Style="{StaticResource ModernTextBox}" Text="500"/>
                                    </StackPanel>
                                    <StackPanel Width="120" Margin="0,0,10,10">
                                        <TextBlock Text="Y" Foreground="#B0B0B0" Margin="0,0,0,4"/>
                                        <TextBox Name="ClickYTextBox" Style="{StaticResource ModernTextBox}" Text="500"/>
                                    </StackPanel>
                                    <StackPanel Width="190" Margin="0,0,10,10">
                                        <TextBlock Text="Type klik" Foreground="#B0B0B0" Margin="0,0,0,4"/>
                                        <ComboBox Name="ClickTypeComboBox" Style="{StaticResource ModernComboBox}">
                                            <ComboBoxItem Content="Left click"/>
                                            <ComboBoxItem Content="Right click"/>
                                            <ComboBoxItem Content="Double left click"/>
                                        </ComboBox>
                                    </StackPanel>
                                </WrapPanel>

                                <WrapPanel Margin="0,0,0,14">
                                    <CheckBox Name="RandomIntervalCheckBox" Content="Random interval" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,10"/>
                                    <TextBlock Text="Min (ms)" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="0,0,6,10"/>
                                    <TextBox Name="RandomMinTextBox" Width="90" Style="{StaticResource ModernTextBox}" Text="80" Margin="0,0,10,10"/>
                                    <TextBlock Text="Max (ms)" Foreground="#B0B0B0" VerticalAlignment="Center" Margin="0,0,6,10"/>
                                    <TextBox Name="RandomMaxTextBox" Width="90" Style="{StaticResource ModernTextBox}" Text="130" Margin="0,0,10,10"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,0,0,10">
                                    <Button Content="Gebruik huidige muispositie" Style="{StaticResource SecondaryButton}" Height="38" Width="210"
                                            Click="CaptureMousePosition_Click" Margin="0,0,8,8"/>
                                    <Button Content="Kies locatie over 3 seconden" Style="{StaticResource SecondaryButton}" Height="38" Width="230"
                                            Click="CaptureMousePositionWithDelay_Click" Margin="0,0,8,8"/>
                                </WrapPanel>

                                <TextBlock Name="MousePositionStatusText" Text="" Foreground="#C8B8E8" Margin="0,2,0,16"/>

                                <Rectangle Height="1" Fill="#15FFFFFF" Margin="0,4,0,14"/>

                                <TextBlock Text="Keyboard scripts" Style="{StaticResource SectionLabel}"/>

                                <TextBox Name="ScriptTextBox"
                                         Background="#F0121212" Foreground="#E0E0E0"
                                         BorderBrush="#15FFFFFF" BorderThickness="1"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         Height="180"
                                         Padding="12"
                                         Text="TEXT Hallo wereld&#x0a;WAIT 250&#x0a;KEY ENTER"/>

                                <TextBlock Margin="0,10,0,10" Foreground="#8B8B8B"
                                           Text="Tip: je kan ook gewoon tekst typen. Commando's: TEXT | WAIT | KEY | DOWN | UP"/>

                                <Border Background="#0F1A1A23" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.15"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Script hotkeys" Foreground="#F3F3F3" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <WrapPanel Margin="0,0,0,8">
                                            <CheckBox Name="ScriptCtrlModifierCheckBox" Content="Ctrl" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                            <CheckBox Name="ScriptAltModifierCheckBox" Content="Alt" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                            <CheckBox Name="ScriptShiftModifierCheckBox" Content="Shift" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                            <CheckBox Name="ScriptWinModifierCheckBox" Content="Win" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                        </WrapPanel>

                                        <WrapPanel>
                                                <TextBlock Text="Toggle start/stop" Foreground="#D5D5D5" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <ComboBox Name="ScriptToggleHotkeyComboBox" Width="120" Style="{StaticResource ModernComboBox}" Margin="0,0,14,8"/>
                                                <TextBlock Text="Toggle pauze" Foreground="#D5D5D5" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <ComboBox Name="ScriptPauseHotkeyComboBox" Width="120" Style="{StaticResource ModernComboBox}" Margin="0,0,14,8"/>
                                            <Button Content="Opslaan script hotkeys" Width="170" Height="38" Style="{StaticResource SecondaryButton}"
                                                    Click="ApplyScriptHotkeys_Click" Margin="0,0,0,8"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <WrapPanel Margin="0,0,0,12">
                                    <CheckBox Name="LoopScriptCheckBox" Content="Loop tot stop" Style="{StaticResource ChipCheckBox}" Margin="0,0,12,8"/>
                                    <Button Name="RecordToggleButton" Content="Start opname" Width="130" Height="40"
                                            Style="{StaticResource SecondaryButton}" Click="RecordToggleButton_Click" Margin="0,0,8,8"/>
                                    <Button Name="PlayScriptButton" Content="Script afspelen" Width="130" Height="40"
                                            Style="{StaticResource PrimaryButton}" Click="PlayScriptButton_Click" Margin="0,0,8,8"/>
                                    <Button Name="StopScriptButton" Content="Stop afspelen" Width="120" Height="40"
                                            Style="{StaticResource SecondaryButton}" Click="StopScriptButton_Click" Margin="0,0,8,8"/>
                                        <TextBlock Name="KeyboardStatusText" Text="Status: geen" Foreground="#B0B0B0"
                                               VerticalAlignment="Center" Margin="0,0,0,8"/>
                                </WrapPanel>

                                <Border Background="#0F1A1A23" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.15"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <WrapPanel Margin="0,0,0,8">
                                            <TextBlock Text="Preset naam" Foreground="#D5D5D5" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <TextBox Name="PresetNameTextBox" Width="180" Style="{StaticResource ModernTextBox}" Text="Default" Margin="0,0,10,8"/>
                                            <TextBlock Text="Bestaande presets" Foreground="#D5D5D5" VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <ComboBox Name="PresetComboBox" Width="180" Style="{StaticResource ModernComboBox}" Margin="0,0,10,8"/>
                                        </WrapPanel>

                                        <WrapPanel>
                                            <Button Content="Save" Width="74" Height="34" Style="{StaticResource SecondaryButton}" Click="SavePreset_Click" Margin="0,0,8,0"/>
                                            <Button Content="Load" Width="74" Height="34" Style="{StaticResource SecondaryButton}" Click="LoadPreset_Click" Margin="0,0,8,0"/>
                                            <Button Content="Delete" Width="74" Height="34" Style="{StaticResource SecondaryButton}" Click="DeletePreset_Click" Margin="0,0,8,0"/>
                                            <Button Content="Refresh" Width="74" Height="34" Style="{StaticResource SecondaryButton}" Click="RefreshPresets_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="2" Margin="0,12,0,0" Foreground="#8E8E8E" FontSize="10"
                           Text="Simple mode is standaard. Open Advanced functies alleen als je extra nodig hebt."/>
            </Grid>
        </DockPanel>
    </Border>
</Window>